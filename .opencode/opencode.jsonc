{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "default_agent": "default",
  "permission": "allow",
  "provider": {
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "env": ["ANTHROPIC_API_KEY"],
      "options": { "apiKey": "{env:ANTHROPIC_API_KEY}" }
    },
    "openai": {
      "npm": "@ai-sdk/openai",
      "env": ["OPENAI_API_KEY"],
      "options": { "apiKey": "{env:OPENAI_API_KEY}" }
    }
  }
}
